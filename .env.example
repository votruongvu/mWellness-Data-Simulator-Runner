# Copy to `.env` and point at your local MWDS backend. The real `.env` is gitignored.
# Consumed by react-native-dotenv as the `@env` module (see babel.config.js, src/config/env.ts).
# If unset/absent, apiBaseUrl stays null -> the app surfaces BACKEND_UNAVAILABLE (never a fake session).
API_BASE_URL=http://localhost:8080
ENV_LABEL=local
