# OS / editor cruft
.DS_Store
__MACOSX/
._*
*.swp
Thumbs.db

# Claude Code runtime state (machine-local)
.claude/state/*
!.claude/state/.gitignore

# React Native / Node app
node_modules/
.metro-health-check*
*.jsbundle
coverage/
*.log
.env*
!.env.example

# iOS — generated by pod install / Xcode (not committed)
ios/Pods/
ios/build/
ios/*.xcworkspace
**/.xcode.env.local
DerivedData/
*.xcuserstate
xcuserdata/
*.pbxuser
*.hmap
*.ipa

# Android — generated by gradle (not committed)
android/build/
android/app/build/
android/.gradle/
android/local.properties
android/.cxx/
*.iml
*.hprof
# Keystores are secret EXCEPT the RN template's committable debug.keystore
*.keystore
!debug.keystore
